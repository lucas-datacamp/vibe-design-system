{
  "name": "Vibe Coding Design System",
  "font": {
    "display": "ui-serif, Georgia, \"Times New Roman\", serif",
    "body": "system-ui, -apple-system, \"Segoe UI\", sans-serif"
  },
  "color": {
    "bg": "oklch(1 0 0)",
    "surface": "oklch(0.975 0 0)",
    "ink": "oklch(0.2 0 0)",
    "muted": "oklch(0.48 0 0)",
    "line": "oklch(0.88 0 0)",
    "primary": "oklch(0.42 0 0)",
    "primary-hover": "oklch(0.36 0 0)",
    "accent": "oklch(0.72 0 0)",
    "accent-ink": "oklch(0.28 0 0)",
    "coral": "oklch(0.58 0 0)",
    "green": "oklch(0.46 0 0)",
    "success": "oklch(0.48 0 0)",
    "error": "oklch(0.52 0 0)",
    "focus": "oklch(0.55 0 0)"
  },
  "space": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2.5rem",
    "2xl": "4rem",
    "3xl": "6rem"
  },
  "text": {
    "caption": "0.8125rem",
    "secondary": "0.9375rem",
    "body": "1rem",
    "subheading": "1.125rem",
    "heading": "1.5rem",
    "display": "clamp(2.25rem, 4vw + 1rem, 4.5rem)"
  },
  "radius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem"
  },
  "z": {
    "dropdown": "10",
    "sticky": "20",
    "modal-backdrop": "30",
    "modal": "40",
    "toast": "50",
    "tooltip": "60"
  },
  "ease": {
    "out-quart": "cubic-bezier(0.25, 1, 0.5, 1)"
  },
  "duration": {
    "fast": "150ms",
    "normal": "220ms"
  }
}
